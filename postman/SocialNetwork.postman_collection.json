{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "SocialNetwork API",
    "description": "Отус ДЗ1 — Заготовка социальной сети",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://localhost:7162", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" },
    { "key": "user_id",  "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "1. Регистрация пользователя",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ivan@example.com\",\n  \"first_name\": \"Иван\",\n  \"second_name\": \"Иванов\",\n  \"birthdate\": \"1990-05-15\",\n  \"gender\": \"male\",\n  \"biography\": \"Люблю программирование и путешествия\",\n  \"city\": \"Москва\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/user/register",
          "host": ["{{base_url}}"],
          "path": ["user", "register"]
        },
        "description": "Создаёт нового пользователя. Возвращает user_id (UUID)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('user_id', json.user_id);",
              "    console.log('Registered user_id:', json.user_id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Вход по email (получить токен)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ivan@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        },
        "description": "Авторизация по email. Токен и user_id автоматически сохраняются."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.token);",
              "    pm.collectionVariables.set('user_id', json.user_id);",
              "    console.log('Token saved, user_id:', json.user_id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Получить анкету пользователя",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/user/get/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["user", "get", "{{user_id}}"]
        },
        "description": "Возвращает анкету пользователя. Требует JWT-токен."
      }
    },
    {
      "name": "4. Вход — неверный пароль (ожидается 401)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ivan@example.com\",\n  \"password\": \"wrongpassword\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "5. Анкета без токена (ожидается 401)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/user/get/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["user", "get", "{{user_id}}"]
        }
      }
    }
  ]
}
